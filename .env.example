# Mapbox (public token for Mapbox GL JS)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token

# Supabase (browser client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Vercel: add the same NEXT_PUBLIC_* keys in
# Project → Settings → Environment Variables (Production / Preview / Development).
# Mapbox token URL restrictions should include your *.vercel.app domain.
